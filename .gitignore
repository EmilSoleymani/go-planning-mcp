.env
node_modules/
dist/
coverage/
docker-compose.override.yml

# graphify: machine-local paths and regenerable cache/cost data
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/cache/
graphify-out/cost.json
graphify-out/.rebuild.lock
# same-day pre-overwrite backup snapshots (export.py _maybe_backup) - local
# rollback safety net, one new dated folder per day, never meant to be committed
graphify-out/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/
